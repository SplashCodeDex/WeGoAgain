rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // default deny
    }

    match /truths/{truthId} {
      allow read: if true; // Publicly readable for now, anyone can swipe
      allow write: if false; // Only written via Admin SDK (our scraper pipeline)
    }
  }
}
